{
  "dashboard": {
    "title": "Retrieval Insights",
    "uid": "retrieval-insights",
    "timezone": "browser",
    "panels": [
      {
        "title": "Avg Unique Chunks per Query (Last 7d)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "rawSql": "SELECT avg(unique_chunks)::float as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Avg Response Time (ms, Last 7d)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 4,
          "y": 0
        },
        "targets": [
          {
            "rawSql": "SELECT avg(response_time_ms)::float as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Total Queries (Last 7d)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 8,
          "y": 0
        },
        "targets": [
          {
            "rawSql": "SELECT count(*)::int as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Path Contribution Trend",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 6
        },
        "targets": [
          {
            "rawSql": "SELECT timestamp as time, vector_count as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          },
          {
            "rawSql": "SELECT timestamp as time, bm25_count as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "B"
          },
          {
            "rawSql": "SELECT timestamp as time, graph_count as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "C"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        },
        "legend": {
          "show": true
        }
      },
      {
        "title": "Eval Score History (Last 10 Runs)",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 6
        },
        "targets": [
          {
            "rawSql": "SELECT faithfulness, relevance, context_precision, answer_correctness, context_recall, hit_rate, created_at::date FROM evalresult ORDER BY created_at DESC LIMIT 10",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Response Time Distribution",
        "type": "histogram",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 14
        },
        "targets": [
          {
            "rawSql": "SELECT response_time_ms FROM retrievalmetric WHERE timestamp > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Overlap Analysis",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 14
        },
        "targets": [
          {
            "rawSql": "SELECT timestamp as time, overlap_vector_bm25::float as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "A"
          },
          {
            "rawSql": "SELECT timestamp as time, vector_only::float as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "B"
          },
          {
            "rawSql": "SELECT timestamp as time, bm25_only::float as value FROM retrievalmetric WHERE timestamp > now() - interval ${__range} ORDER BY timestamp",
            "format": "time_series",
            "refId": "C"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        },
        "legend": {
          "show": true
        }
      },
      {
        "title": "Feedback Correlation",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 14
        },
        "targets": [
          {
            "rawSql": "SELECT f.rating, r.vector_count, r.bm25_count, r.unique_chunks, r.response_time_ms FROM feedback f JOIN retrievalmetric r ON f.query = r.query ORDER BY f.created_at DESC LIMIT 20",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Avg Rating (Last 7d)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 0,
          "y": 22
        },
        "targets": [
          {
            "rawSql": "SELECT COALESCE(AVG(rating)::numeric(3,2), 0) AS value FROM feedback WHERE created_at > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Total Feedback Count (Last 7d)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 4,
          "y": 22
        },
        "targets": [
          {
            "rawSql": "SELECT COUNT(*)::int AS value FROM feedback WHERE created_at > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Low Rating % (<3)",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 8,
          "y": 22
        },
        "targets": [
          {
            "rawSql": "SELECT COALESCE((SUM(CASE WHEN rating < 3 THEN 1 ELSE 0 END)::float / NULLIF(COUNT(*), 0) * 100)::numeric(4,1), 0) AS value FROM feedback WHERE created_at > now() - interval ${__range}",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Rating Distribution",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 28
        },
        "targets": [
          {
            "rawSql": "SELECT rating::text AS metric, COUNT(*)::int AS value FROM feedback WHERE created_at > now() - interval ${__range} GROUP BY rating ORDER BY rating",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Rating Trend (Daily Avg, Last 7d)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 28
        },
        "targets": [
          {
            "rawSql": "SELECT DATE(created_at) AS time, AVG(rating)::numeric(3,2) AS value FROM feedback WHERE created_at > now() - interval ${__range} GROUP BY DATE(created_at) ORDER BY time",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      },
      {
        "title": "Recent Low-Rated Queries (<3)",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 28
        },
        "targets": [
          {
            "rawSql": "SELECT id, rating, LEFT(query, 80) AS query, created_at FROM feedback WHERE rating < 3 AND created_at > now() - interval ${__range} ORDER BY created_at DESC LIMIT 20",
            "format": "table",
            "refId": "A"
          }
        ],
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        }
      }
    ]
  },
  "overwrite": true
}