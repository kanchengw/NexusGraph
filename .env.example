# NexusGraph Environment Configuration Example
# Copy this file to .env and fill in your keys

# ── Application ──
APP_ENV=development
DEBUG=true

# ── DashScope LLM (Qwen) ──
# Get your API key: https://bailian.console.aliyun.com/
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key
DEFAULT_LLM_MODEL=qwen3.6-flash

# ── DashScope Embedding ──
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v3

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# ── Neo4j ──
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ── GraphRAG ──
GRAPHRAG_CHUNK_SIZE=512
GRAPHRAG_CHUNK_OVERLAP=64
GRAPHRAG_TOP_K=5
GRAPHRAG_VECTOR_INDEX_NAME=rag_chunks

# ── Langfuse (observability) ──
# https://langfuse.com/
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Evaluation (uses same DashScope key) ──
EVALUATION_LLM=qwen-plus
EVALUATION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVALUATION_API_KEY=your-dashscope-api-key
EVALUATION_SLEEP_TIME=5

# ── Misc ──
VALKEY_HOST=                # leave empty to disable
ALLOWED_ORIGINS=*
LOG_LEVEL=DEBUG
LOG_FORMAT=console
SESSION_NAMING_ENABLED=true

# Long-term memory (mem0 + pgvector)
LONG_TERM_MEMORY_MODEL=qwen3.6-flash
LONG_TERM_MEMORY_EMBEDDER_MODEL=text-embedding-v3
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory

# Grafana (used by Docker compose)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
